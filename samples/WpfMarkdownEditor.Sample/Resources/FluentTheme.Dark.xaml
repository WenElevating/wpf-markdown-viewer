<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══════════════════════════════════════════════════
         Dark Theme — High-Tech Web Style
         Deep blacks, electric cyan accent, blue-tinted grays
         ═══════════════════════════════════════════════════ -->

    <!-- Layer Tokens (Background) -->
    <SolidColorBrush x:Key="LayerBackgroundBaseBrush" Color="#111111"/>
    <SolidColorBrush x:Key="LayerBackgroundAltBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="LayerBackgroundCardBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="LayerBackgroundOverlayBrush" Color="#1E1E1EE0"/>

    <!-- Text Tokens -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E8F0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8090A0"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#4A5568"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#000000"/>

    <!-- Stroke Tokens -->
    <SolidColorBrush x:Key="StrokeCardBrush" Color="#2A2E35"/>
    <SolidColorBrush x:Key="StrokeDividerBrush" Color="#2A2E35"/>
    <SolidColorBrush x:Key="StrokeSurfaceBrush" Color="#FFFFFF08"/>

    <!-- Accent Tokens — Electric Cyan -->
    <SolidColorBrush x:Key="AccentDefaultBrush" Color="#00D4FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#33DDFF"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#00B8E0"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#00D4FF10"/>

    <!-- Control Tokens -->
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#FFFFFF0A"/>
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#FFFFFF12"/>
    <SolidColorBrush x:Key="ControlSelectedBrush" Color="#252830"/>
    <SolidColorBrush x:Key="ControlFillBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#3A3E45"/>

    <!-- Shadow Tokens -->
    <SolidColorBrush x:Key="ShadowFlyoutBrush" Color="#00000030"/>
    <SolidColorBrush x:Key="ShadowDialogBrush" Color="#00000040"/>

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!-- Legacy compatibility keys -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111111"/>
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#252830"/>
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#2A2E35"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#FFFFFF0A"/>
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="#FFFFFF12"/>
    <SolidColorBrush x:Key="SegmentBackgroundBrush" Color="#252830"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
</ResourceDictionary>
