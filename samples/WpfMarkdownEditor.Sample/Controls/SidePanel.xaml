<UserControl x:Class="WpfMarkdownEditor.Sample.Controls.SidePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfMarkdownEditor.Sample.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Bar -->
        <Border Grid.Row="0" Background="{DynamicResource LayerBackgroundAltBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tab Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- Explorer Tab -->
                    <Grid x:Name="ExplorerTabContainer">
                        <Button x:Name="ExplorerTabButton" Click="OnExplorerTabClick"
                                Background="Transparent" BorderThickness="0"
                                Padding="14,0" Height="36" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"
                                           x:Name="ExplorerTabIcon"
                                           Foreground="{DynamicResource AccentDefaultBrush}"/>
                                <TextBlock x:Name="ExplorerTabText" Text="Explorer"
                                           FontFamily="{StaticResource UIFont}" FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Active indicator -->
                        <Border x:Name="ExplorerActiveIndicator" Height="2"
                                Background="{DynamicResource AccentDefaultBrush}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                Margin="8,0" CornerRadius="1"/>
                    </Grid>

                    <!-- Outline Tab -->
                    <Grid x:Name="OutlineTabContainer">
                        <Button x:Name="OutlineTabButton" Click="OnOutlineTabClick"
                                Background="Transparent" BorderThickness="0"
                                Padding="14,0" Height="36" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8AF;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"
                                           x:Name="OutlineTabIcon"
                                           Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="OutlineTabText" Text="Outline"
                                           FontFamily="{StaticResource UIFont}" FontSize="12"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Active indicator (hidden by default) -->
                        <Border x:Name="OutlineActiveIndicator" Height="2"
                                Background="{DynamicResource AccentDefaultBrush}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                Margin="8,0" CornerRadius="1" Visibility="Collapsed"/>
                    </Grid>
                </StackPanel>

                <!-- Open Folder Button (Explorer tab only) -->
                <Button x:Name="OpenFolderButton" Grid.Column="1"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="36" Height="36"
                        Click="OnOpenFolderClick"
                        ToolTip="打开文件夹">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <!-- Explorer Content -->
            <local:FileTreeView x:Name="ExplorerContent" ShowHeader="False"/>

            <!-- Outline Content -->
            <local:OutlineView x:Name="OutlineContent" ShowHeader="False"
                               Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
