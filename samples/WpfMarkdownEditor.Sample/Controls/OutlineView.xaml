<UserControl x:Class="WpfMarkdownEditor.Sample.Controls.OutlineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20,12" Background="{DynamicResource LayerBackgroundAltBrush}"
                Visibility="{Binding ShowHeader, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Outline" FontWeight="SemiBold" FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       FontFamily="{StaticResource UIFont}" VerticalAlignment="Center"/>
        </Border>

        <!-- Outline List -->
        <ListView x:Name="OutlineList" Grid.Row="1"
                  Background="{DynamicResource LayerBackgroundBaseBrush}"
                  BorderThickness="0"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  FontFamily="{StaticResource UIFont}" FontSize="12"
                  SelectionChanged="OnOutlineItemSelected"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Padding="6">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="Margin" Value="2,1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" CornerRadius="6">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSubtleBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis">
                        <TextBlock.Margin>
                            <MultiBinding Converter="{StaticResource LevelToMarginConverter}">
                                <Binding Path="Level"/>
                            </MultiBinding>
                        </TextBlock.Margin>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="1">
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="2">
                                        <Setter Property="FontSize" Value="12.5"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="3">
                                        <Setter Property="FontSize" Value="12"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="4">
                                        <Setter Property="FontSize" Value="11.5"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="5">
                                        <Setter Property="FontSize" Value="11.5"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="6">
                                        <Setter Property="FontSize" Value="11.5"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
