<Window x:Class="WpfMarkdownEditor.Sample.Controls.SaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="420" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="#60000000">
        <Border Background="{DynamicResource LayerBackgroundCardBrush}"
                CornerRadius="8"
                BorderBrush="{DynamicResource StrokeCardBrush}"
                BorderThickness="1"
                Margin="40"
                Padding="28"
                Width="340">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="未保存的更改"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>

                <!-- Message -->
                <TextBlock x:Name="MessageText"
                           FontFamily="{StaticResource UIFont}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           Margin="0,0,0,28"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Save -->
                    <Button x:Name="SaveButton"
                            Content="保存"
                            Click="OnSave"
                            MinWidth="96" Height="36"
                            Margin="0,0,10,0"
                            Style="{StaticResource AccentButtonStyle}"/>

                    <!-- Discard -->
                    <Button x:Name="DiscardButton"
                            Content="不保存"
                            Click="OnDiscard"
                            MinWidth="96" Height="36"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryButtonStyle}"/>

                    <!-- Cancel -->
                    <Button x:Name="CancelButton"
                            Content="取消"
                            Click="OnCancel"
                            MinWidth="96" Height="36"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</Window>
