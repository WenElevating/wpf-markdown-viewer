<UserControl x:Class="WpfMarkdownEditor.Sample.Controls.FormattingToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource LayerBackgroundAltBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="0,0,0,1">
        <DockPanel Margin="16,0">
            <!-- Right side: Theme toggle + Preview switch -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Preview Toggle -->
                <ToggleButton x:Name="PreviewToggle" Content="Preview"
                              Margin="4,0"
                              Style="{StaticResource FluentToggleButtonStyle}"
                              Cursor="Hand"
                              Click="OnTogglePreview"/>
                <!-- Separator -->
                <Border Width="1" Height="20" Background="{DynamicResource StrokeDividerBrush}" Margin="12,0"/>
                <!-- Theme Toggle Segment -->
                <Border Background="{DynamicResource ControlSelectedBrush}"
                        CornerRadius="6" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnLight" Content="Light" Tag="Active"
                                Style="{StaticResource SegmentButtonStyle}"
                                Click="OnLightTheme"/>
                        <Button x:Name="BtnDark" Content="Dark"
                                Style="{StaticResource SegmentButtonStyle}"
                                Click="OnDarkTheme"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Left side: Formatting buttons -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Format group: B I </> ~~S~~ -->
                <Button Click="OnBold" ToolTip="Bold (Ctrl+B)" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                </Button>
                <Button Click="OnItalic" ToolTip="Italic (Ctrl+I)" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                </Button>
                <Button Click="OnCode" ToolTip="Inline Code" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="&lt;/&gt;" FontFamily="Cascadia Code, Consolas" FontSize="11"/>
                </Button>
                <Button Click="OnStrikethrough" ToolTip="Strikethrough" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="S" TextDecorations="Strikethrough" FontSize="13"/>
                </Button>

                <!-- Separator -->
                <Border Width="1" Height="20" Background="{DynamicResource StrokeDividerBrush}" Margin="8,0"/>

                <!-- Heading group -->
                <Button Click="OnH1" ToolTip="Heading 1" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="H1" FontWeight="SemiBold" FontSize="12"/>
                </Button>
                <Button Click="OnH2" ToolTip="Heading 2" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="H2" FontWeight="SemiBold" FontSize="12"/>
                </Button>
                <Button Click="OnH3" ToolTip="Heading 3" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock Text="H3" FontWeight="SemiBold" FontSize="12"/>
                </Button>

                <!-- Separator -->
                <Border Width="1" Height="20" Background="{DynamicResource StrokeDividerBrush}" Margin="8,0"/>

                <!-- List group -->
                <Button Click="OnUnorderedList" ToolTip="Bullet List" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FD;" FontSize="12"/>
                </Button>
                <Button Click="OnOrderedList" ToolTip="Numbered List" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FE;" FontSize="12"/>
                </Button>
                <Button Click="OnBlockquote" ToolTip="Blockquote" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8AF;" FontSize="12"/>
                </Button>

                <!-- Separator -->
                <Border Width="1" Height="20" Background="{DynamicResource StrokeDividerBrush}" Margin="8,0"/>

                <!-- Insert group -->
                <Button Click="OnInsertLink" ToolTip="Insert Link" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71B;" FontSize="12"/>
                </Button>
                <Button Click="OnInsertImage" ToolTip="Insert Image" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B9;" FontSize="12"/>
                </Button>
                <Button Click="OnInsertTable" ToolTip="Insert Table" Style="{StaticResource ToolbarButtonStyle}" Padding="10,6">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE712;" FontSize="12"/>
                </Button>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
