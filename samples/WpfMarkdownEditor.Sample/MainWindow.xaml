<Window
    x:Class="WpfMarkdownEditor.Sample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:WpfMarkdownEditor.Wpf.Controls;assembly=WpfMarkdownEditor.Wpf"
    Title="{DynamicResource Loc.MainWindow.TitleSuffix}"
    Width="1200"
    Height="800"
    MinWidth="600"
    MinHeight="400"
    Background="{DynamicResource WindowBackgroundBrush}"
    Icon="app.ico"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Menu Bar  -->
        <Border
            Grid.Row="0"
            Padding="4,0"
            Background="{DynamicResource SurfaceBackgroundBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <!--  Sidebar Toggle  -->
                <Button
                    Background="Transparent"
                    BorderThickness="0"
                    Click="OnToggleSidebar"
                    Cursor="Hand"
                    ToolTip="{DynamicResource Loc.MainWindow.ToggleSidebar}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="Bd"
                                Padding="8,5"
                                Background="Transparent"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                                <StackPanel Width="14" VerticalAlignment="Center">
                                    <Rectangle
                                        Height="1.5"
                                        Fill="{DynamicResource TextSecondaryBrush}"
                                        RadiusX="1" />
                                    <Rectangle
                                        Height="1.5"
                                        Margin="0,2.5,0,0"
                                        Fill="{DynamicResource TextSecondaryBrush}"
                                        RadiusX="1" />
                                    <Rectangle
                                        Height="1.5"
                                        Margin="0,2.5,0,0"
                                        Fill="{DynamicResource TextSecondaryBrush}"
                                        RadiusX="1" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PressedBackgroundBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Border
                    Width="1"
                    Height="18"
                    Margin="4,2"
                    Background="{DynamicResource DividerBrush}" />

                <!--  File  -->
                <ToggleButton
                    x:Name="FileMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.File}"
                    IsChecked="{Binding IsOpen, ElementName=FilePopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="FilePopup"
                    AllowsTransparency="True"
                    HorizontalOffset="{Binding ElementName=FilePopup, Path=ActualWidth}"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=FileMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button
                                Click="OnNewFile"
                                Content="{DynamicResource Loc.MainWindow.NewFile}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+N" />
                            <Button
                                Click="OnOpenFile"
                                Content="{DynamicResource Loc.MainWindow.OpenFile}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+O" />
                            <Button
                                Click="OnSaveFile"
                                Content="{DynamicResource Loc.MainWindow.SaveFile}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+S" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  Edit  -->
                <ToggleButton
                    x:Name="EditMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.Edit}"
                    IsChecked="{Binding IsOpen, ElementName=EditPopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="EditPopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=EditMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button
                                Click="OnUndo"
                                Content="{DynamicResource Loc.MainWindow.Undo}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+Z" />
                            <Button
                                Click="OnRedo"
                                Content="{DynamicResource Loc.MainWindow.Redo}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+Y" />
                            <Border
                                Height="1"
                                Margin="4,2"
                                Background="{DynamicResource DividerBrush}" />
                            <Button
                                Click="OnFind"
                                Content="{DynamicResource Loc.MainWindow.Find}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+F" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  Paragraph  -->
                <ToggleButton
                    x:Name="ParagraphMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.Paragraph}"
                    IsChecked="{Binding IsOpen, ElementName=ParagraphPopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="ParagraphPopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=ParagraphMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button
                                Click="OnHeading1"
                                Content="{DynamicResource Loc.MainWindow.Heading1}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnHeading2"
                                Content="{DynamicResource Loc.MainWindow.Heading2}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnHeading3"
                                Content="{DynamicResource Loc.MainWindow.Heading3}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Border
                                Height="1"
                                Margin="4,2"
                                Background="{DynamicResource DividerBrush}" />
                            <Button
                                Click="OnQuote"
                                Content="{DynamicResource Loc.MainWindow.Blockquote}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnOrderedList"
                                Content="{DynamicResource Loc.MainWindow.OrderedList}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnUnorderedList"
                                Content="{DynamicResource Loc.MainWindow.BulletList}"
                                Style="{StaticResource MenuItemStyle}" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  Format  -->
                <ToggleButton
                    x:Name="FormatMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.Format}"
                    IsChecked="{Binding IsOpen, ElementName=FormatPopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="FormatPopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=FormatMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button
                                Click="OnBold"
                                Content="{DynamicResource Loc.MainWindow.Bold}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+B" />
                            <Button
                                Click="OnItalic"
                                Content="{DynamicResource Loc.MainWindow.Italic}"
                                Style="{StaticResource MenuItemStyle}"
                                Tag="Ctrl+I" />
                            <Button
                                Click="OnStrikethrough"
                                Content="{DynamicResource Loc.MainWindow.Strikethrough}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnInlineCode"
                                Content="{DynamicResource Loc.MainWindow.InlineCode}"
                                Style="{StaticResource MenuItemStyle}" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  Insert  -->
                <ToggleButton
                    x:Name="InsertMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.Insert}"
                    IsChecked="{Binding IsOpen, ElementName=InsertPopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="InsertPopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=InsertMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button
                                Click="OnLink"
                                Content="{DynamicResource Loc.MainWindow.Link}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnCodeBlock"
                                Content="{DynamicResource Loc.MainWindow.CodeBlock}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnTable"
                                Content="{DynamicResource Loc.MainWindow.Table}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Button
                                Click="OnHorizontalRule"
                                Content="{DynamicResource Loc.MainWindow.HorizontalRule}"
                                Style="{StaticResource MenuItemStyle}" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  View  -->
                <ToggleButton
                    x:Name="ViewMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.View}"
                    IsChecked="{Binding IsOpen, ElementName=ViewPopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="ViewPopup"
                    AllowsTransparency="True"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=ViewMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button
                                Click="OnToggleSidebarFromMenu"
                                Content="{DynamicResource Loc.MainWindow.ToggleSidebar}"
                                Style="{StaticResource MenuItemStyle}" />
                            <Border
                                Height="1"
                                Margin="4,2"
                                Background="{DynamicResource DividerBrush}" />
                            <TextBlock
                                Padding="16,7,16,4"
                                FontFamily="Segoe UI Variable, Segoe UI"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="{DynamicResource Loc.MainWindow.Themes}" />
                            <StackPanel x:Name="ThemeListPanel" />
                            <Border
                                Height="1"
                                Margin="4,2"
                                Background="{DynamicResource DividerBrush}" />
                            <TextBlock
                                Padding="16,7,16,4"
                                FontFamily="Segoe UI Variable, Segoe UI"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="{DynamicResource Loc.MainWindow.Language}" />
                            <StackPanel x:Name="LanguageListPanel" />
                        </StackPanel>
                    </Border>
                </Popup>

                <!--  Tools  -->
                <ToggleButton
                    x:Name="ToolsMenuBtn"
                    Content="{DynamicResource Loc.MainWindow.Tools}"
                    IsChecked="{Binding IsOpen, ElementName=ToolsPopup, Mode=TwoWay}"
                    Style="{StaticResource MenuHeaderStyle}" />
                <Popup
                    x:Name="ToolsPopup"
                    AllowsTransparency="True"
                    Opened="OnTranslatePopupOpened"
                    Placement="Bottom"
                    PlacementTarget="{Binding ElementName=ToolsMenuBtn}"
                    PopupAnimation="Slide"
                    StaysOpen="False">
                    <Border
                        Margin="0,2,0,0"
                        Padding="4"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        Button.Click="OnPopupItemClick"
                        CornerRadius="8"
                        Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="220">
                            <!--  Cancel translation (shown during translation)  -->
                            <Button
                                x:Name="CancelTranslateBtn"
                                Click="OnCancelTranslate"
                                Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="Bd"
                                            Padding="12,8"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Text="&#xE711;" />
                                                <TextBlock
                                                    FontFamily="Segoe UI Variable, Segoe UI"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    Text="{DynamicResource Loc.MainWindow.CancelTranslation}" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel x:Name="TranslateLanguagePanel">
                                <!--  Clear translation  -->
                                <Button
                                    x:Name="ClearTranslationBtn"
                                    Click="OnClearTranslation"
                                    Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                x:Name="Bd"
                                                Padding="12,8"
                                                Background="{DynamicResource HoverBackgroundBrush}"
                                                CornerRadius="4"
                                                Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource AccentBrush}"
                                                        Text="&#xE711;" />
                                                    <TextBlock
                                                        FontFamily="Segoe UI Variable, Segoe UI"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource AccentBrush}"
                                                        Text="{DynamicResource Loc.MainWindow.ClearTranslation}" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!--  Engine selection  -->
                                <StackPanel Margin="12,6" Orientation="Horizontal">
                                    <RadioButton
                                        x:Name="EngineBaiduRadio"
                                        Margin="0,0,12,0"
                                        Checked="OnEngineRadioChanged"
                                        Content="Baidu"
                                        FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        GroupName="TranslationEngine"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="EngineOpenAIRadio"
                                        Checked="OnEngineRadioChanged"
                                        Content="OpenAI"
                                        FontFamily="Segoe UI Variable, Segoe UI"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        GroupName="TranslationEngine" />
                                </StackPanel>
                                <Border
                                    Height="1"
                                    Margin="4,2"
                                    Background="{DynamicResource DividerBrush}" />
                                <Button
                                    Click="OnTranslateToEnglish"
                                    Content="{DynamicResource Loc.MainWindow.TranslateToEnglish}"
                                    Style="{StaticResource MenuItemStyle}" />
                                <Button
                                    Click="OnTranslateToChinese"
                                    Content="{DynamicResource Loc.MainWindow.TranslateToChinese}"
                                    Style="{StaticResource MenuItemStyle}" />
                                <Button
                                    Click="OnTranslateToJapanese"
                                    Content="{DynamicResource Loc.MainWindow.TranslateToJapanese}"
                                    Style="{StaticResource MenuItemStyle}" />
                                <Button
                                    Click="OnTranslateToKorean"
                                    Content="{DynamicResource Loc.MainWindow.TranslateToKorean}"
                                    Style="{StaticResource MenuItemStyle}" />
                                <Border
                                    Height="1"
                                    Margin="4,2"
                                    Background="{DynamicResource DividerBrush}" />
                                <Button
                                    Click="OnTranslationSettings"
                                    Content="{DynamicResource Loc.MainWindow.TranslationSettings}"
                                    Style="{StaticResource MenuItemStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </Border>

        <!--  Editor Area  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Sidebar (drawer)  -->
            <Border
                x:Name="SidebarPanel"
                Grid.Column="0"
                Width="0"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,1,0"
                ClipToBounds="True">
                <Grid Width="260">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Tab Headers  -->
                    <Grid Grid.Row="0" Margin="16,12,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock
                                x:Name="TabHistory"
                                Margin="0,0,0,6"
                                Cursor="Hand"
                                FontFamily="Segoe UI Variable, Segoe UI"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                MouseLeftButtonDown="OnTabHistory"
                                Text="{DynamicResource Loc.MainWindow.History}" />
                            <Border
                                x:Name="HistoryUnderline"
                                Width="20"
                                Height="2"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="1" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock
                                x:Name="TabOutline"
                                Margin="0,0,0,6"
                                Cursor="Hand"
                                FontFamily="Segoe UI Variable, Segoe UI"
                                FontSize="12"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                MouseLeftButtonDown="OnTabOutline"
                                Text="{DynamicResource Loc.MainWindow.Outline}" />
                            <Border
                                x:Name="OutlineUnderline"
                                Width="20"
                                Height="2"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="1"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>

                    <!--  Tab Content  -->
                    <Grid Grid.Row="1">
                        <ScrollViewer
                            x:Name="HistoryPanel"
                            Padding="8"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="HistoryList">
                                <TextBlock
                                    Margin="0,32,0,0"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Variable, Segoe UI"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Text="{DynamicResource Loc.MainWindow.NoFilesOpened}" />
                            </StackPanel>
                        </ScrollViewer>
                        <ScrollViewer
                            x:Name="OutlinePanel"
                            Padding="8"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="Collapsed">
                            <StackPanel x:Name="OutlineList">
                                <TextBlock
                                    Margin="0,32,0,0"
                                    HorizontalAlignment="Center"
                                    FontFamily="Segoe UI Variable, Segoe UI"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    Text="{DynamicResource Loc.MainWindow.NoHeadingsFound}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!--  Editor + Search  -->
            <Grid Grid.Column="1">
                <ctrl:MarkdownEditor x:Name="Editor" />

                <!--  Search Panel (overlay, top-right)  -->
                <Border
                    x:Name="SearchPanel"
                    Margin="8,4,8,0"
                    Padding="6,3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="10"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Effect="{StaticResource PopupShadowEffect}"
                    Visibility="Collapsed">
                    <DockPanel>
                        <Button
                            Padding="4,2"
                            Click="OnSearchClose"
                            DockPanel.Dock="Right"
                            Style="{StaticResource FormatButtonStyle}"
                            ToolTip="{DynamicResource Loc.MainWindow.SearchCloseTooltip}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="11"
                                Text="&#xE711;" />
                        </Button>
                        <Button
                            Padding="4,2"
                            Click="OnSearchNext"
                            DockPanel.Dock="Right"
                            Style="{StaticResource FormatButtonStyle}"
                            ToolTip="{DynamicResource Loc.MainWindow.SearchNextTooltip}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10"
                                Text="&#xE70D;" />
                        </Button>
                        <Button
                            Padding="4,2"
                            Click="OnSearchPrevious"
                            DockPanel.Dock="Right"
                            Style="{StaticResource FormatButtonStyle}"
                            ToolTip="{DynamicResource Loc.MainWindow.SearchPreviousTooltip}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10"
                                Text="&#xE70E;" />
                        </Button>
                        <TextBlock
                            x:Name="SearchCount"
                            Margin="6,0"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right"
                            FontFamily="Segoe UI Variable, Segoe UI"
                            FontSize="11"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Text="" />
                        <TextBox
                            x:Name="SearchInput"
                            Width="180"
                            Padding="4,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource TextPrimaryBrush}"
                            FontFamily="Segoe UI Variable, Segoe UI"
                            FontSize="12"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            PreviewKeyDown="OnSearchInputKeyDown"
                            TextChanged="OnSearchInputTextChanged" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!--  Status Bar  -->
        <Border
            Grid.Row="2"
            Background="{DynamicResource SurfaceBackgroundBrush}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock
                    x:Name="StatusText"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource UIFont}"
                    FontSize="11"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="{DynamicResource Loc.Status.Ready}" />
                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource UIFont}"
                    FontSize="11"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    Text="{DynamicResource Loc.MainWindow.EncodingStatus}" />
            </Grid>
        </Border>
    </Grid>
</Window>
