<Window x:Class="WpfMarkdownEditor.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:WpfMarkdownEditor.Wpf.Controls;assembly=WpfMarkdownEditor.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Markdown Editor"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border x:Name="RootBorder" 
            CornerRadius="8" 
            Background="{DynamicResource WindowBackgroundBrush}" 
            BorderBrush="{DynamicResource WindowBorderBrush}" 
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Margin="16,0">
                    <!-- Title -->
                    <TextBlock VerticalAlignment="Center"
                               FontFamily="{StaticResource UIFont}" FontSize="13">
                        <Run Text="Markdown " FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Run Text="Editor" FontWeight="SemiBold"
                             Foreground="{DynamicResource AccentBrush}"/>
                    </TextBlock>

                    <!-- Toolbar -->
                    <DockPanel LastChildFill="False" HorizontalAlignment="Right">
                        <!-- Open -->
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Click="OnOpenFile" ToolTip="Open file">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Open"/>
                            </StackPanel>
                        </Button>

                        <!-- Save -->
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Click="OnSaveFile" ToolTip="Save file">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Height="16"
                                Background="{DynamicResource DividerBrush}" Margin="6,0"/>

                        <!-- Theme Toggle -->
                        <Border Background="{DynamicResource SegmentBackgroundBrush}"
                                CornerRadius="5" Padding="2" Margin="2,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnLight" Content="Light" Tag="Active"
                                        Style="{StaticResource SegmentButtonStyle}"
                                        Click="OnLightTheme"/>
                                <Button x:Name="BtnDark" Content="Dark"
                                        Style="{StaticResource SegmentButtonStyle}"
                                        Click="OnDarkTheme"/>
                            </StackPanel>
                        </Border>

                        <!-- Separator -->
                        <Border Width="1" Height="16"
                                Background="{DynamicResource DividerBrush}" Margin="6,0"/>

                        <!-- Window Controls -->
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Width="40" Click="OnMinimizeClick" ToolTip="Minimize">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Width="40" Click="OnMaximizeClick" ToolTip="Maximize/Restore">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Width="40" Click="OnCloseClick" ToolTip="Close">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Editor -->
            <ctrl:MarkdownEditor x:Name="Editor" Grid.Row="1"/>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <Grid Margin="16,0">
                    <TextBlock x:Name="StatusText" Text="Ready"
                               FontFamily="{StaticResource UIFont}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="{StaticResource UIFont}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Text="UTF-8 · Markdown"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
