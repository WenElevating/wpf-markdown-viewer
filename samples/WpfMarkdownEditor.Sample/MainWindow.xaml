<Window x:Class="WpfMarkdownEditor.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:WpfMarkdownEditor.Wpf.Controls;assembly=WpfMarkdownEditor.Wpf"
        Title="Markdown Editor"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Formatting Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- File -->
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnOpenFile" ToolTip="Open file">
                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnSaveFile" ToolTip="Save file">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                </Button>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Headings -->
                <Button Style="{StaticResource FormatButtonStyle}" Content="H1" Click="OnHeading1" ToolTip="Heading 1" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13" FontWeight="SemiBold"/>
                <Button Style="{StaticResource FormatButtonStyle}" Content="H2" Click="OnHeading2" ToolTip="Heading 2" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                <Button Style="{StaticResource FormatButtonStyle}" Content="H3" Click="OnHeading3" ToolTip="Heading 3" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" FontWeight="SemiBold"/>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Text formatting -->
                <Button Style="{StaticResource FormatButtonStyle}" Content="B" Click="OnBold" ToolTip="Bold (Ctrl+B)" FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"/>
                <Button Style="{StaticResource FormatButtonStyle}" Content="I" Click="OnItalic" ToolTip="Italic (Ctrl+I)" FontStyle="Italic" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnStrikethrough" ToolTip="Strikethrough">
                    <TextBlock Text="S" TextDecorations="Strikethrough" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnInlineCode" ToolTip="Inline Code">
                    <TextBlock Text="&lt;/&gt;" FontFamily="Cascadia Code, Consolas" FontSize="11" VerticalAlignment="Center"/>
                </Button>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Insert -->
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnLink" ToolTip="Insert Link" Content="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnQuote" ToolTip="Blockquote" Content="&#xE8AF;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnUnorderedList" ToolTip="Bullet List" Content="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnOrderedList" ToolTip="Numbered List" Content="&#xE8FE;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnCodeBlock" ToolTip="Code Block" Content="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnTable" ToolTip="Insert Table" Content="&#xE7E3;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnHorizontalRule" ToolTip="Horizontal Rule" Content="&#xE5C3;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Theme toggle -->
                <Border Background="{DynamicResource SegmentBackgroundBrush}"
                        CornerRadius="5" Padding="2" Margin="4,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnLight" Content="Light" Tag="Active"
                                Style="{StaticResource SegmentButtonStyle}"
                                Click="OnLightTheme"/>
                        <Button x:Name="BtnDark" Content="Dark"
                                Style="{StaticResource SegmentButtonStyle}"
                                Click="OnDarkTheme"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Editor -->
        <ctrl:MarkdownEditor x:Name="Editor" Grid.Row="1"/>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="StatusText" Text="Ready"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="UTF-8 · Markdown"/>
            </Grid>
        </Border>
    </Grid>
</Window>
