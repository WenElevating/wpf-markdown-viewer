<Window x:Class="WpfMarkdownEditor.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:WpfMarkdownEditor.Wpf.Controls;assembly=WpfMarkdownEditor.Wpf"
        Title="Markdown Viewer"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Sidebar Toggle -->
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnToggleSidebar" ToolTip="Toggle Sidebar">
                    <TextBlock Text="&#xE137;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                </Button>
                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="4,2"/>

                <!-- File -->
                <ToggleButton x:Name="FileMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="File"
                              IsChecked="{Binding IsOpen, ElementName=FilePopup, Mode=TwoWay}"/>
                <Popup x:Name="FilePopup" PlacementTarget="{Binding ElementName=FileMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button Style="{StaticResource MenuItemStyle}" Content="New File" Tag="Ctrl+N" Click="OnNewFile"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Open File" Tag="Ctrl+O" Click="OnOpenFile"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Save File" Tag="Ctrl+S" Click="OnSaveFile"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Edit -->
                <ToggleButton x:Name="EditMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="Edit"
                              IsChecked="{Binding IsOpen, ElementName=EditPopup, Mode=TwoWay}"/>
                <Popup x:Name="EditPopup" PlacementTarget="{Binding ElementName=EditMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button Style="{StaticResource MenuItemStyle}" Content="Undo" Tag="Ctrl+Z" Click="OnUndo"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Redo" Tag="Ctrl+Y" Click="OnRedo"/>
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Find" Tag="Ctrl+F" Click="OnFind"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Paragraph -->
                <ToggleButton x:Name="ParagraphMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="Paragraph"
                              IsChecked="{Binding IsOpen, ElementName=ParagraphPopup, Mode=TwoWay}"/>
                <Popup x:Name="ParagraphPopup" PlacementTarget="{Binding ElementName=ParagraphMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button Style="{StaticResource MenuItemStyle}" Content="Heading 1" Click="OnHeading1"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Heading 2" Click="OnHeading2"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Heading 3" Click="OnHeading3"/>
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Blockquote" Click="OnQuote"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Ordered List" Click="OnOrderedList"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Bullet List" Click="OnUnorderedList"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Format -->
                <ToggleButton x:Name="FormatMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="Format"
                              IsChecked="{Binding IsOpen, ElementName=FormatPopup, Mode=TwoWay}"/>
                <Popup x:Name="FormatPopup" PlacementTarget="{Binding ElementName=FormatMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button Style="{StaticResource MenuItemStyle}" Content="Bold" Tag="Ctrl+B" Click="OnBold"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Italic" Tag="Ctrl+I" Click="OnItalic"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Strikethrough" Click="OnStrikethrough"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Inline Code" Click="OnInlineCode"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Insert -->
                <ToggleButton x:Name="InsertMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="Insert"
                              IsChecked="{Binding IsOpen, ElementName=InsertPopup, Mode=TwoWay}"/>
                <Popup x:Name="InsertPopup" PlacementTarget="{Binding ElementName=InsertMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button Style="{StaticResource MenuItemStyle}" Content="Link" Click="OnLink"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Code Block" Click="OnCodeBlock"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Table" Click="OnTable"/>
                            <Button Style="{StaticResource MenuItemStyle}" Content="Horizontal Rule" Click="OnHorizontalRule"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- View -->
                <ToggleButton x:Name="ViewMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="View"
                              IsChecked="{Binding IsOpen, ElementName=ViewPopup, Mode=TwoWay}"/>
                <Popup x:Name="ViewPopup" PlacementTarget="{Binding ElementName=ViewMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="200">
                            <Button Style="{StaticResource MenuItemStyle}" Content="Toggle Sidebar" Click="OnToggleSidebarFromMenu"/>
                            <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                            <TextBlock Text="Themes" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Padding="16,7,16,4" FontWeight="SemiBold"/>
                            <StackPanel x:Name="ThemeListPanel"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Tools -->
                <ToggleButton x:Name="ToolsMenuBtn" Style="{StaticResource MenuHeaderStyle}" Content="Tools"
                              IsChecked="{Binding IsOpen, ElementName=ToolsPopup, Mode=TwoWay}"/>
                <Popup x:Name="ToolsPopup" PlacementTarget="{Binding ElementName=ToolsMenuBtn}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide"
                       Opened="OnTranslatePopupOpened">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="4" Margin="0,2,0,0"
                            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Effect="{StaticResource PopupShadowEffect}">
                        <StackPanel MinWidth="220">
                            <!-- Cancel translation (shown during translation) -->
                            <Button x:Name="CancelTranslateBtn" Click="OnCancelTranslate" Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Padding="12,8" CornerRadius="4" Cursor="Hand" Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Cancel Translation" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel x:Name="TranslateLanguagePanel">
                                <!-- Clear translation -->
                                <Button x:Name="ClearTranslationBtn" Click="OnClearTranslation" Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Padding="12,8" CornerRadius="4" Cursor="Hand"
                                                    Background="{DynamicResource HoverBackgroundBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text="Clear Translation" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                                               Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Engine selection -->
                                <StackPanel Orientation="Horizontal" Margin="12,6">
                                    <RadioButton x:Name="EngineBaiduRadio" GroupName="TranslationEngine" Content="Baidu" IsChecked="True"
                                                 FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"
                                                 Checked="OnEngineRadioChanged"/>
                                    <RadioButton x:Name="EngineOpenAIRadio" GroupName="TranslationEngine" Content="OpenAI"
                                                 FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                                 Checked="OnEngineRadioChanged"/>
                                </StackPanel>
                                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                                <Button Style="{StaticResource MenuItemStyle}" Content="→ English" Click="OnTranslateToEnglish"/>
                                <Button Style="{StaticResource MenuItemStyle}" Content="→ Chinese" Click="OnTranslateToChinese"/>
                                <Button Style="{StaticResource MenuItemStyle}" Content="→ Japanese" Click="OnTranslateToJapanese"/>
                                <Button Style="{StaticResource MenuItemStyle}" Content="→ Korean" Click="OnTranslateToKorean"/>
                                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                                <Button Style="{StaticResource MenuItemStyle}" Content="Translation Settings..." Click="OnTranslationSettings"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </Border>

        <!-- Editor Area -->
        <Grid Grid.Row="1">
            <!-- Editor (full width, behind sidebar) -->
            <ctrl:MarkdownEditor x:Name="Editor"/>

            <!-- Sidebar (overlay on top of editor) -->
            <Border x:Name="SidebarPanel"
                    Width="0"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True"
                    HorizontalAlignment="Left"
                    Panel.ZIndex="1">
                <Grid Width="260">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab Headers -->
                    <Grid Grid.Row="0" Margin="8,8,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabHistory" Grid.Column="0" Click="OnTabHistory"
                                Style="{StaticResource SidebarTabStyle}" Tag="Active">
                            <TextBlock Text="History" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"/>
                        </Button>
                        <Button x:Name="TabOutline" Grid.Column="1" Click="OnTabOutline"
                                Style="{StaticResource SidebarTabStyle}">
                            <TextBlock Text="Outline" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Tab Content -->
                    <Grid Grid.Row="1">
                        <ScrollViewer x:Name="HistoryPanel" VerticalScrollBarVisibility="Auto" Padding="8">
                            <StackPanel x:Name="HistoryList">
                                <TextBlock Text="No files opened yet" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,32,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                        <ScrollViewer x:Name="OutlinePanel" VerticalScrollBarVisibility="Auto"
                                      Padding="8" Visibility="Collapsed">
                            <StackPanel x:Name="OutlineList">
                                <TextBlock Text="No headings found" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,32,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Search Panel (overlay, top-right) -->
            <Border x:Name="SearchPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="6,3" Margin="8,4,8,0"
                    Panel.ZIndex="10"
                    Effect="{StaticResource PopupShadowEffect}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FormatButtonStyle}" Click="OnSearchClose"
                            ToolTip="Close (Esc)" Padding="4,2">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FormatButtonStyle}" Click="OnSearchNext"
                            ToolTip="Next (Enter)" Padding="4,2">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FormatButtonStyle}" Click="OnSearchPrevious"
                            ToolTip="Previous (Shift+Enter)" Padding="4,2">
                        <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <TextBlock x:Name="SearchCount" DockPanel.Dock="Right" Text=""
                               FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="6,0"/>
                    <TextBox x:Name="SearchInput" Width="180"
                             FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                             Background="Transparent" BorderThickness="0" Padding="4,0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" VerticalContentAlignment="Center"
                             TextChanged="OnSearchInputTextChanged"
                             PreviewKeyDown="OnSearchInputKeyDown"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="StatusText" Text="Ready"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="UTF-8 · Markdown"/>
            </Grid>
        </Border>
    </Grid>
</Window>
