<Window x:Class="WpfMarkdownEditor.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:WpfMarkdownEditor.Wpf.Controls;assembly=WpfMarkdownEditor.Wpf"
        Title="Markdown Editor"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Formatting Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Sidebar Toggle -->
                <Button x:Name="SidebarToggleBtn" Style="{StaticResource FormatButtonStyle}"
                        Click="OnToggleSidebar" ToolTip="Toggle Sidebar">
                    <TextBlock Text="&#xE137;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                </Button>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- File -->
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnOpenFile" ToolTip="Open file">
                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnSaveFile" ToolTip="Save file">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                </Button>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Headings -->
                <Button Style="{StaticResource FormatButtonStyle}" Content="H1" Click="OnHeading1" ToolTip="Heading 1" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13" FontWeight="SemiBold"/>
                <Button Style="{StaticResource FormatButtonStyle}" Content="H2" Click="OnHeading2" ToolTip="Heading 2" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                <Button Style="{StaticResource FormatButtonStyle}" Content="H3" Click="OnHeading3" ToolTip="Heading 3" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" FontWeight="SemiBold"/>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Text formatting -->
                <Button Style="{StaticResource FormatButtonStyle}" Content="B" Click="OnBold" ToolTip="Bold (Ctrl+B)" FontWeight="Bold" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"/>
                <Button Style="{StaticResource FormatButtonStyle}" Content="I" Click="OnItalic" ToolTip="Italic (Ctrl+I)" FontStyle="Italic" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnStrikethrough" ToolTip="Strikethrough">
                    <TextBlock Text="S" TextDecorations="Strikethrough" FontFamily="Segoe UI Variable, Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnInlineCode" ToolTip="Inline Code">
                    <TextBlock Text="&lt;/&gt;" FontFamily="Cascadia Code, Consolas" FontSize="11" VerticalAlignment="Center"/>
                </Button>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Insert -->
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnLink" ToolTip="Insert Link" Content="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnQuote" ToolTip="Blockquote" Content="&#xE8AF;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnUnorderedList" ToolTip="Bullet List" Content="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnOrderedList" ToolTip="Numbered List" Content="&#xE8FE;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnCodeBlock" ToolTip="Code Block" Content="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnTable" ToolTip="Insert Table" Content="&#xE7E3;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                <Button Style="{StaticResource FormatButtonStyle}" Click="OnHorizontalRule" ToolTip="Horizontal Rule" Content="&#xE5C3;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Translate Dropdown -->
                <Grid VerticalAlignment="Center" Margin="2,0">
                    <ToggleButton x:Name="TranslateToggle"
                                  Style="{StaticResource ThemePickerStyle}"
                                  IsChecked="{Binding IsOpen, ElementName=TranslatePopup, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Translate"
                                       FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                       VerticalAlignment="Center" Margin="6,0,4,0"/>
                            <TextBlock Text="&#xE972;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                       VerticalAlignment="Center" Opacity="0.5"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup x:Name="TranslatePopup"
                           PlacementTarget="{Binding ElementName=TranslateToggle}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Slide"
                           Opened="OnTranslatePopupOpened">
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="8" Padding="4" Margin="0,4,0,0"
                                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                                Effect="{StaticResource PopupShadowEffect}">
                            <StackPanel>
                                <!-- Cancel button (shown during translation) -->
                                <Button x:Name="CancelTranslateBtn"
                                        Click="OnCancelTranslate"
                                        Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Padding="12,8" CornerRadius="4" Cursor="Hand"
                                                    Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Cancel Translation" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Idle content (engine + languages) -->
                                <StackPanel x:Name="TranslateLanguagePanel">
                                    <!-- Clear translation button (shown when preview is translated) -->
                                    <Button x:Name="ClearTranslationBtn"
                                            Click="OnClearTranslation"
                                            Visibility="Collapsed">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Padding="12,8" CornerRadius="4" Cursor="Hand"
                                                        Background="{DynamicResource HoverBackgroundBrush}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                        <TextBlock Text="Clear Translation" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Engine selection -->
                                    <StackPanel Orientation="Horizontal" Margin="8,6">
                                        <RadioButton x:Name="EngineBaiduRadio" GroupName="TranslationEngine" Content="Baidu" IsChecked="True"
                                                     FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                                     Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,12,0"
                                                     Checked="OnEngineRadioChanged"/>
                                        <RadioButton x:Name="EngineOpenAIRadio" GroupName="TranslationEngine" Content="OpenAI"
                                                     FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                                     Checked="OnEngineRadioChanged"/>
                                    </StackPanel>
                                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                                    <!-- Language options -->
                                    <Button Click="OnTranslateToEnglish">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Padding="12,8" Cursor="Hand" Background="Transparent"><TextBlock Text="→ English" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Click="OnTranslateToChinese">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Padding="12,8" Cursor="Hand" Background="Transparent"><TextBlock Text="→ Chinese" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Click="OnTranslateToJapanese">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Padding="12,8" Cursor="Hand" Background="Transparent"><TextBlock Text="→ Japanese" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                    </Button>
                                    <Button Click="OnTranslateToKorean">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Padding="12,8" Cursor="Hand" Background="Transparent"><TextBlock Text="→ Korean" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                    </Button>
                                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,2"/>
                                    <Button Click="OnTranslationSettings">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Padding="12,8" Cursor="Hand" Background="Transparent"><TextBlock Text="Translation Settings..." FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="6,2"/>

                <!-- Theme Picker Dropdown -->
                <Grid VerticalAlignment="Center" Margin="2,0">
                    <ToggleButton x:Name="ThemeToggle"
                                  Style="{StaticResource ThemePickerStyle}"
                                  IsChecked="{Binding IsOpen, ElementName=ThemePopup, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,0,0"/>
                            <TextBlock x:Name="CurrentThemeName" Text="GitHub"
                                       FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                       VerticalAlignment="Center" Margin="6,0,4,0"/>
                            <TextBlock Text="&#xE972;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                       VerticalAlignment="Center" Opacity="0.5"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup x:Name="ThemePopup"
                           PlacementTarget="{Binding ElementName=ThemeToggle}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Slide">
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="8" Padding="4" Margin="0,4,0,0"
                                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                                Effect="{StaticResource PopupShadowEffect}">
                            <StackPanel x:Name="ThemeListPanel"/>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Sidebar + Editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border x:Name="SidebarPanel"
                    Grid.Column="0"
                    Width="0"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True"
                    HorizontalAlignment="Left">
                <Grid Width="260" Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab Headers -->
                    <Grid Grid.Row="0" Margin="8,8,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TabHistory" Grid.Column="0" Click="OnTabHistory"
                                Style="{StaticResource SidebarTabStyle}" Tag="Active">
                            <TextBlock Text="History" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"/>
                        </Button>
                        <Button x:Name="TabOutline" Grid.Column="1" Click="OnTabOutline"
                                Style="{StaticResource SidebarTabStyle}">
                            <TextBlock Text="Outline" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"/>
                        </Button>
                    </Grid>

                    <!-- Tab Content -->
                    <Grid Grid.Row="1">
                        <!-- History Panel -->
                        <ScrollViewer x:Name="HistoryPanel" VerticalScrollBarVisibility="Auto" Padding="8">
                            <StackPanel x:Name="HistoryList">
                                <TextBlock Text="No files opened yet" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,32,0,0"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Outline Panel -->
                        <ScrollViewer x:Name="OutlinePanel" VerticalScrollBarVisibility="Auto"
                                      Padding="8" Visibility="Collapsed">
                            <StackPanel x:Name="OutlineList">
                                <TextBlock Text="No headings found" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,32,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Editor -->
            <ctrl:MarkdownEditor x:Name="Editor" Grid.Column="1"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="StatusText" Text="Ready"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right"
                           FontFamily="{StaticResource UIFont}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Text="UTF-8 · Markdown"/>
            </Grid>
        </Border>
    </Grid>
</Window>
