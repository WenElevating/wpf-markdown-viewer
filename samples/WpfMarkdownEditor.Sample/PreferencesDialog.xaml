<Window
    x:Class="WpfMarkdownEditor.Sample.PreferencesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{DynamicResource Loc.MainWindow.Preferences}"
    Width="420"
    Height="260"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock
            Margin="0,0,0,16"
            FontSize="18"
            FontWeight="SemiBold"
            Text="{DynamicResource Loc.MainWindow.Preferences}" />
        <TextBlock Margin="0,0,0,4" Text="{DynamicResource Loc.MainWindow.Language}" />
        <ComboBox
            x:Name="LanguageBox"
            Margin="0,0,0,12"
            DisplayMemberPath="Name" />
        <TextBlock Margin="0,0,0,4" Text="{DynamicResource Loc.MainWindow.Themes}" />
        <ComboBox
            x:Name="ThemeBox"
            Margin="0,0,0,16"
            DisplayMemberPath="Name" />
        <Button
            x:Name="TranslationSettingsButton"
            Margin="0,0,0,16"
            Click="OnTranslationSettingsClick"
            Content="{DynamicResource Loc.MainWindow.TranslationSettings}" />
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Click="OnCancelClick"
                Content="{DynamicResource Loc.Common.Cancel}" />
            <Button Click="OnSaveClick" Content="{DynamicResource Loc.Common.Save}" />
        </StackPanel>
    </StackPanel>
</Window>
