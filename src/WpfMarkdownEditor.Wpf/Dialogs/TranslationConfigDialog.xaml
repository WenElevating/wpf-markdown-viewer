<Window x:Class="WpfMarkdownEditor.Wpf.Dialogs.TranslationConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Translation Settings"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        PreviewKeyDown="OnDialogPreviewKeyDown">
    <Window.Resources>
        <!-- Primary button template (accent color) -->
        <ControlTemplate x:Key="PrimaryButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Padding="{TemplateBinding Padding}" CornerRadius="6"
                    Background="{DynamicResource AccentBrush}" Cursor="Hand">
                <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
                           Foreground="White" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- Secondary button template (muted) -->
        <ControlTemplate x:Key="SecondaryButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Padding="{TemplateBinding Padding}" CornerRadius="6"
                    Background="{DynamicResource SegmentBackgroundBrush}" Cursor="Hand">
                <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>
    <Border Background="{DynamicResource CardBackgroundBrush}"
            CornerRadius="12" Margin="16"
            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar with close button -->
            <Border Grid.Row="0" Background="Transparent"
                    MouseLeftButtonDown="OnTitleBarMouseDown"
                    CornerRadius="12,12,0,0">
                <Grid Margin="24,20,16,0">
                    <TextBlock x:Name="DialogTitle"
                               Text="Select Translation Engine"
                               FontFamily="Segoe UI Variable, Segoe UI" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" Padding="8"
                            Click="OnCancelClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24,12,24,24">
                <!-- Engine selection (first-run) -->
                <StackPanel x:Name="EngineSelectionPanel" Visibility="Visible">
                    <!-- Baidu engine card -->
                    <Border x:Name="BaiduCard" CornerRadius="8" Padding="16,14" Margin="0,0,0,8"
                            BorderThickness="2" Cursor="Hand"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Background="{DynamicResource HoverBackgroundBrush}"
                            MouseLeftButtonDown="OnBaiduCardClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Baidu Translate" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="百度翻译 · Fast &amp; reliable" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <RadioButton x:Name="EngineBaidu" GroupName="Engine" IsChecked="True"
                                         Grid.Column="2" VerticalAlignment="Center" IsHitTestVisible="False"
                                         Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>
                    </Border>

                    <!-- OpenAI engine card -->
                    <Border x:Name="OpenAICard" CornerRadius="8" Padding="16,14" Margin="0,0,0,20"
                            BorderThickness="1" Cursor="Hand"
                            BorderBrush="{DynamicResource DividerBrush}"
                            Background="Transparent"
                            MouseLeftButtonDown="OnOpenAICardClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="OpenAI Compatible" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Qwen · Zhipu · DeepSeek · OpenAI" FontFamily="Segoe UI Variable, Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <RadioButton x:Name="EngineOpenAI" GroupName="Engine"
                                         Grid.Column="2" VerticalAlignment="Center" IsHitTestVisible="False"
                                         Foreground="{DynamicResource AccentBrush}"/>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="OnCancelClick" Padding="24,10" Margin="0,0,8,0"
                                Template="{StaticResource SecondaryButtonTemplate}"/>
                        <Button Content="Next" Click="OnNextClick" Padding="24,10"
                                Template="{StaticResource PrimaryButtonTemplate}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Baidu config -->
                <StackPanel x:Name="BaiduConfigPanel" Visibility="Collapsed">
                    <TextBlock Text="Baidu Translate Configuration"
                               FontFamily="Segoe UI Variable, Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>

                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI" FontSize="12" Margin="0,0,0,16">
                        <Hyperlink NavigateUri="https://fanyi-api.baidu.com/" RequestNavigate="OnLinkClick"
                                   Foreground="{DynamicResource AccentBrush}" TextDecorations="None">
                            Get App ID &amp; Secret Key from fanyi-api.baidu.com →
                        </Hyperlink>
                    </TextBlock>

                    <TextBlock Text="App ID" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="BaiduAppId" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
                             Padding="10,8" Margin="0,0,0,16"
                             Background="{DynamicResource SurfaceBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"/>

                    <TextBlock Text="Secret Key" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="BaiduSecretKey" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
                                 Padding="10,8" Margin="0,0,0,20"
                                 Background="{DynamicResource SurfaceBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="OnCancelClick" Padding="24,10" Margin="0,0,8,0"
                                Template="{StaticResource SecondaryButtonTemplate}"/>
                        <Button Content="Save &amp; Translate" Click="OnSaveClick" Padding="24,10"
                                Template="{StaticResource PrimaryButtonTemplate}"/>
                    </StackPanel>
                </StackPanel>

                <!-- OpenAI config -->
                <StackPanel x:Name="OpenAIConfigPanel" Visibility="Collapsed">
                    <TextBlock Text="OpenAI Compatible Configuration"
                               FontFamily="Segoe UI Variable, Segoe UI" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Service" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ServiceComboBox" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
                              SelectionChanged="OnServiceChanged"
                              Padding="10,8" Margin="0,0,0,16"
                              Background="{DynamicResource SurfaceBackgroundBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource DividerBrush}"/>

                    <TextBlock Text="API Address" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="ApiEndpoint" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
                             Padding="10,8" Margin="0,0,0,16"
                             Background="{DynamicResource SurfaceBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"/>

                    <TextBlock Text="API Key" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ApiKey" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
                                 Padding="10,8" Margin="0,0,0,16"
                                 Background="{DynamicResource SurfaceBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"/>

                    <TextBlock Text="Model" FontFamily="Segoe UI Variable, Segoe UI" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="ModelName" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14"
                             Padding="10,8" Margin="0,0,0,20"
                             Background="{DynamicResource SurfaceBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="OnCancelClick" Padding="24,10" Margin="0,0,8,0"
                                Template="{StaticResource SecondaryButtonTemplate}"/>
                        <Button Content="Save &amp; Translate" Click="OnSaveClick" Padding="24,10"
                                Template="{StaticResource PrimaryButtonTemplate}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
