<UserControl x:Class="WpfMarkdownEditor.Wpf.Controls.TranslationProgressOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#80000000"
             Visibility="Collapsed">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12" Padding="32,28"
                MinWidth="300" MaxWidth="420"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                Opacity="0" x:Name="Card">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.25"/>
            </Border.Effect>
            <StackPanel>
                <!-- Spinning icon + title -->
                <TextBlock x:Name="GlobeIcon"
                           Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                           HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="SpinTransform" Angle="0"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <TextBlock x:Name="StatusTitle"
                           Text="Translating..."
                           FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <TextBlock x:Name="StatusDetail"
                           Text=""
                           FontSize="12"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>

                <!-- Progress bar -->
                <ProgressBar x:Name="ProgressBar"
                             Height="6" Margin="0,16,0,0"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource SegmentBackgroundBrush}"/>

                <!-- Elapsed time -->
                <TextBlock x:Name="ElapsedText"
                           Text="0s elapsed"
                           FontSize="11"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>

                <!-- Error message (hidden by default) -->
                <TextBlock x:Name="ErrorText"
                           Text="" FontSize="12"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           Foreground="#E74C3C"
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           Margin="0,12,0,0" Visibility="Collapsed"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Click="OnCancelClick"
                            FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
                            Padding="24,8"
                            Background="{DynamicResource SegmentBackgroundBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="RetryButton"
                            Content="Retry"
                            Click="OnRetryClick"
                            FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
                            Padding="24,8" Margin="8,0,0,0"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"/>
                    <Button x:Name="CloseButton"
                            Content="Close"
                            Click="OnCloseClick"
                            FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
                            Padding="24,8" Margin="8,0,0,0"
                            Background="{DynamicResource SegmentBackgroundBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
